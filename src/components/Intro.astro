---
import { Image } from 'astro:assets'
import heroImage from '../assets/hero-image.jpg'
---

<section id="intro" class="section-container flex flex-col md:flex-row items-center justify-between gap-12 min-h-screen">
  <div class="w-full md:w-1/2 flex items-center justify-center">
    <div class="relative">
      <Image src={heroImage} alt="Larry Xue" class="rounded-lg shadow-2xl w-auto h-[500px] object-cover" />
      <div class="absolute inset-0 bg-gradient-to-tr from-leaf-green-600/30 to-tree-brown-600/30 rounded-lg"></div>
    </div>
  </div>
  <div class="w-full md:w-1/2 text-center md:text-left space-y-4">
    <h1 class="text-5xl md:text-7xl font-bold mb-4 text-transparent bg-clip-text bg-gradient-to-r from-leaf-green-600 to-tree-brown-600 dark:from-leaf-green-400 dark:to-tree-brown-400">
      Yujian (Larry) Xue
    </h1>
    <h2 class="text-3xl md:text-5xl text-tree-brown-800 dark:text-leaf-green-300 mb-6">Full Stack Developer & UI/UX Enthusiast</h2>
    <p class="text-lg md:text-xl max-w-2xl mx-auto md:mx-0 leading-relaxed mb-4">
      👋 Hello! I'm Larry, a <span class="font-semibold text-leaf-green-700 dark:text-leaf-green-400">passionate Full Stack Developer</span> with 2+ years of experience. Currently at <span class="font-semibold text-tree-brown-700 dark:text-tree-brown-400">eSurfing Cloud</span>, I blend creativity with cutting-edge tech to bring ideas to life.
    </p>
    <p class="text-lg md:text-xl font-semibold mt-4">Let's build something amazing together!</p>
    <div class="flex flex-wrap gap-4 justify-center md:justify-start mt-8">
      <a href="#contact" class="btn btn-primary">Get in Touch</a>
      <a href="#projects" class="btn btn-secondary">View My Work</a>
    </div>
  </div>
</section>

<style>
  .btn {
    @apply px-6 py-3 rounded-full text-lg font-semibold transition-all duration-300 transform hover:scale-105 hover:shadow-lg;
  }
</style>

<script>
  import { gsap } from "gsap";
  
  gsap.from("#intro > div", {
    duration: 1,
    y: 50,
    opacity: 0,
    stagger: 0.3,
    ease: "power3.out"
  });

  gsap.from("#intro h1, #intro h2, #intro p, #intro ul li, #intro .btn", {
    duration: 1,
    y: 30,
    opacity: 0,
    stagger: 0.1,
    ease: "power3.out",
    delay: 0.5
  });
</script>
