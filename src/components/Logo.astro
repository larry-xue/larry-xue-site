<div id="logo" class="fixed top-5 left-5 z-50 font-bold text-xl"></div>

<style>
  @keyframes blink {
    0% { opacity: 1; }
    50% { opacity: 0; }
    100% { opacity: 1; }
  }

  #logo::after {
    content: '_';
    animation: blink 0.7s infinite;
  }
</style>

<script>
  const logo = document.getElementById('logo');
  const text = 'larryxue.dev';
  let index = 0;

  function typeText() {
    if (index < text.length && logo) {
      logo.textContent += text.charAt(index);
      index++;
      setTimeout(typeText, 100);
      console.log('hello');
    }
  }

  window.addEventListener('load', () => {
    setTimeout(typeText, 1000);
  });
</script>
